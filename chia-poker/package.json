{
  "name": "chia-poker",
  "version": "0.1.0",
  "private": true,
  "description": "Global-scale poker platform with Chia blockchain settlement",
  "license": "MIT",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "lint": "pnpm -r run lint",
    "dev:api": "pnpm --filter @chia-poker/api dev",
    "dev:gateway": "pnpm --filter @chia-poker/gateway dev",
    "typecheck": "pnpm -r run typecheck"
  }
}
